generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             Int            @id @default(autoincrement())
  username       String         @unique @db.VarChar(100)
  email          String         @unique @db.VarChar(150)
  password       String         @map("password_hash") @db.VarChar(255)
  deviceToken    String?        @map("device_token") @db.VarChar(500)
  isActive       Boolean        @default(true) @map("is_active")
  lastLogin      DateTime?      @map("last_login")
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")
  resolvedAlerts Alert[]        @relation("ResolvedBy")
  devices        Device[]
  notifications  Notification[]

  @@index([email], map: "idx_users_email")
  @@index([username], map: "idx_users_username")
  @@map("users")
}

model Device {
  id             Int             @id @default(autoincrement())
  userId         Int             @map("user_id")
  name           String          @db.VarChar(100)
  description    String?
  deviceKey      String          @unique @map("device_key") @db.VarChar(255)
  status         DeviceStatus    @default(OFFLINE)
  location       String?         @db.VarChar(255)
  lastSeen       DateTime?       @map("last_seen")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  isActive       Boolean         @default(true) @map("is_active")
  windowStatus   Boolean         @default(false) @map("window_status")
  fanStatus      Boolean         @default(false) @map("fan_status")
  alerts         Alert[]
  deviceSettings DeviceSettings?
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_devices_user")
  @@index([deviceKey], map: "idx_devices_key")
  @@index([status], map: "idx_devices_status")
  @@map("devices")
}

model DeviceSettings {
  id       Int @id @default(autoincrement())
  deviceId Int @unique @map("device_id")

  // Umbrales específicos por sensor
  mq2ThresholdPpm Float @default(300.0) @map("mq2_threshold_ppm")
  mq3ThresholdPpm Float @default(150.0) @map("mq3_threshold_ppm")
  mq5ThresholdPpm Float @default(200.0) @map("mq5_threshold_ppm")
  mq9ThresholdPpm Float @default(100.0) @map("mq9_threshold_ppm")

  // Valores R0 específicos (Calibración)
  mq2R0 Float @default(5.5) @map("mq2_r0")
  mq3R0 Float @default(2.0) @map("mq3_r0")
  mq5R0 Float @default(20.0) @map("mq5_r0")
  mq9R0 Float @default(12.0) @map("mq9_r0")

  buzzerEnabled        Boolean  @default(true) @map("buzzer_enabled")
  ledEnabled           Boolean  @default(true) @map("led_enabled")
  notifyUser           Boolean  @default(true) @map("notify_user")
  notificationCooldown Int      @default(300) @map("notification_cooldown")
  autoShutoff          Boolean  @default(false) @map("auto_shutoff")
  updatedAt            DateTime @updatedAt @map("updated_at")
  device               Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([deviceId], map: "idx_settings_device")
  @@map("device_settings")
}

model Alert {
  id            Int            @id @default(autoincrement())
  deviceId      Int            @map("device_id")
  alertType     AlertType      @map("alert_type")
  severity      AlertSeverity  @default(MEDIUM)
  gasType       GasType?       @map("gas_type")
  message       String         @db.VarChar(255)
  gasValuePpm   Float?         @map("gas_value_ppm")
  voltageValue  Float?         @map("voltage_value")
  resolved      Boolean        @default(false)
  resolvedAt    DateTime?      @map("resolved_at")
  resolvedBy    Int?           @map("resolved_by")
  createdAt     DateTime       @default(now()) @map("created_at")
  device        Device         @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  resolver      User?          @relation("ResolvedBy", fields: [resolvedBy], references: [id])
  notifications Notification[]

  @@index([deviceId], map: "idx_alerts_device")
  @@index([createdAt], map: "idx_alerts_created")
  @@index([resolved], map: "idx_alerts_resolved")
  @@index([deviceId, resolved, createdAt], map: "idx_alerts_active")
  @@map("alerts")
}

model Notification {
  id        Int              @id @default(autoincrement())
  userId    Int              @map("user_id")
  alertId   Int?             @map("alert_id")
  title     String           @db.VarChar(255)
  message   String
  type      NotificationType @default(ALERT)
  read      Boolean          @default(false)
  sent      Boolean          @default(false)
  createdAt DateTime         @default(now()) @map("created_at")
  alert     Alert?           @relation(fields: [alertId], references: [id])
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_notif_user")
  @@index([userId, read], map: "idx_notif_unread")
  @@index([createdAt], map: "idx_notif_created")
  @@map("notifications")
}

enum DeviceStatus {
  ONLINE
  OFFLINE
  MAINTENANCE
}

enum AlertType {
  GAS_DETECTED
  SENSOR_ERROR
  OFFLINE
  MAINTENANCE_REQUIRED
}

enum AlertSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum GasType {
  LPG // MQ2 - Gas licuado de petróleo / Propano
  METHANE // MQ5 - Metano / Gas natural
  ALCOHOL // MQ3 - Alcohol / Etanol
  CO // MQ9 - Monóxido de carbono
  SMOKE // MQ2 - Humo
  UNKNOWN
}

enum NotificationType {
  ALERT
  INFO
  WARNING
  SUCCESS
}
